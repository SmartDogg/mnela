    "turndown": "^7.2.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.3.15",
    "@types/pdf-parse": "^1.1.4",
    "@types/turndown": "^5.0.5",
    "@types/yauzl": "^2.10.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
