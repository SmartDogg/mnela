// Mnela database schema — see docs/dev/ORIGINAL_TZ.md §4
// Source of truth for all persistent state.

generator client {
  provider      = "prisma-client-js"
  // `native` lets pnpm dev keep working on every developer host (macOS arm/
  // intel, Linux glibc, Linux musl, Windows). The extra debian engine ships
  // with the prod runtime image which is `node:22-slim` (Debian, openssl 3.x),
  // so the multi-stage Dockerfile doesn't have to re-run `prisma generate`
  // inside the smaller runtime layer.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// Sources and raw documents
// =====================================================================

enum SourceType {
  chatgpt_export
  claude_export
  obsidian_vault
  manual_upload
  api_ingest
  telegram
  voice_note
  email
  web_clip
  // Pinned messages from /ask are promoted to Documents so they flow
  // through the same enrichment pipeline as imported documents.
  chat
  // Daily notes were merged into Document (ADR-0050). The legacy
  // DailyNote table was removed; rows live here with metadata.date+mood.
  daily
}

enum DocumentStatus {
  raw
  parsed
  enriching
  enriched
  failed
  archived
}

model Document {
  id          String         @id @default(cuid())

  source      SourceType
  sourceId    String?

  title       String
  rawText     String         @db.Text
  cleanText   String?        @db.Text
  contentHash String         @unique
  tokenCount  Int?

  language    String?
  type        String?
  metadata    Json?

  status      DocumentStatus @default(raw)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  ingestedAt  DateTime       @default(now())
  enrichedAt  DateTime?
  archivedAt  DateTime?

  chunks           DocumentChunk[]
  attachments      Attachment[]    @relation("AttachmentOwner")
  /**
   * If this document was promoted from an image attachment, the originating
   * Attachment row points here via `linkedDocumentId`. Empty for normal docs.
   */
  imageAttachments Attachment[]    @relation("AttachmentImage")
  documentEntities DocumentEntity[]
  documentProjects DocumentProject[]
  edgesAsEvidence  Edge[]            @relation("EdgeEvidence")
  decisions        Decision[]
  synthesisOf      Conversation[]    @relation("ConversationSynthesis")

  vaultPath String?

  @@index([source, sourceId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model DocumentChunk {
  id         String  @id @default(cuid())
  documentId String
  chunkIndex Int
  text       String  @db.Text
  tokenCount Int
  metadata   Json?

  // Reserved for future vector search:
  // embedding Unsupported("vector(1024)")?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, chunkIndex])
}

model Attachment {
  id          String  @id @default(cuid())
  documentId  String?
  filename    String
  mimeType    String
  size        Int
  path        String
  contentHash String
  metadata    Json?
  ocrText     String? @db.Text
  description String? @db.Text

  // Image attachments are also promoted to a standalone Document(type=image)
  // so they appear as first-class entries in /documents and can carry their
  // own entity links. `linkedDocumentId` points at that companion document.
  // Non-image attachments keep this null.
  linkedDocumentId String?

  analyzedAt DateTime?
  createdAt  DateTime  @default(now())

  document       Document? @relation("AttachmentOwner", fields: [documentId], references: [id], onDelete: SetNull)
  linkedDocument Document? @relation("AttachmentImage", fields: [linkedDocumentId], references: [id], onDelete: SetNull)

  @@index([contentHash])
  @@index([linkedDocumentId])
}

// =====================================================================
// Knowledge graph
// =====================================================================

enum EntityType {
  project
  person
  organization
  technology
  concept
  product
  service
  bug
  feature
  custom
}

model Entity {
  id             String     @id @default(cuid())
  name           String
  normalizedName String
  type           EntityType
  description    String?    @db.Text
  aliases        String[]
  metadata       Json?

  // Soft merge: duplicate entities can be folded into a canonical one.
  mergedIntoId String?
  mergedInto   Entity?  @relation("EntityMerge", fields: [mergedIntoId], references: [id])
  mergedFrom   Entity[] @relation("EntityMerge")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentEntities DocumentEntity[]
  edgesFrom        Edge[]           @relation("EdgeFrom")
  edgesTo          Edge[]           @relation("EdgeTo")

  @@unique([normalizedName, type])
  @@index([type])
}

enum LinkStatus {
  auto_confirmed
  needs_review
  manual
  rejected
}

model Edge {
  id           String     @id @default(cuid())
  fromId       String
  toId         String
  relationType String
  confidence   Float      @default(1.0)
  status       LinkStatus @default(auto_confirmed)

  evidenceDocumentId String?
  evidenceChunkId    String?

  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  invalidatedById String?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  from        Entity    @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to          Entity    @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)
  evidenceDoc Document? @relation("EdgeEvidence", fields: [evidenceDocumentId], references: [id], onDelete: SetNull)

  @@unique([fromId, toId, relationType])
  @@index([status])
}

model DocumentEntity {
  documentId String
  entityId   String
  mentions   Int     @default(1)
  context    String? @db.Text

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entity   Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([documentId, entityId])
}

// =====================================================================
// Projects, decisions, daily notes
// =====================================================================

// ADR-0051: project lifecycle is `active` (user-owned), `suggested` (detector
// candidate awaiting accept/dismiss), or `dismissed` (rejected; revives only
// when the signal grows materially — see signatureMetrics).
enum ProjectStatus {
  active
  suggested
  dismissed
}

// How a project was created. `manual` is the classic user-driven path;
// `suggested_batch` and `suggested_cluster` come from the detector
// (project_suggest job) — the former groups an import batch, the latter
// groups documents that share an entity cluster across batches.
enum ProjectSource {
  manual
  suggested_batch
  suggested_cluster
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(active)
  source      ProjectSource @default(manual)
  contextMd   String?       @db.Text

  /// When `source` is suggested_*, autoFill is implicitly true (detector
  /// linked the documents itself). When `source=manual`, autoFill=true means
  /// the user opted into a background scan that links candidate docs.
  autoFill Boolean @default(false)

  /// Deterministic fingerprint of the cluster this project represents
  /// (e.g., `batch:<batchId>` or `cluster:<sortedEntityHash>:<docBucket>`).
  /// Used by the detector to skip clusters it already emitted, and as the
  /// revival key for dismissed suggestions.
  signature String?

  /// Snapshot of the cluster signal at emit time:
  /// `{ docCount, topEntities: string[] }`. Compared to the live signal on
  /// every detector pass; meaningful growth (≥50% docs, or ≥2 new top
  /// entities) revives a dismissed suggestion as a fresh row.
  signatureMetrics Json?

  /// Source import batch id for `suggested_batch` projects (matches the
  /// `__import.batchId` stamped on Document.metadata). Null for everything
  /// else.
  batchId String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents DocumentProject[]
  decisions Decision[]

  @@index([status])
  @@index([signature])
  @@index([batchId])
}

/// How a document came to be attached to a project. `suggested` links are
/// removed on dismiss; `manual` and `autoFill` survive.
enum DocumentProjectLinkSource {
  manual
  suggested
  autoFill
}

model DocumentProject {
  documentId String
  projectId  String
  linkSource DocumentProjectLinkSource @default(manual)
  createdAt  DateTime                   @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([documentId, projectId])
}

model Decision {
  id             String  @id @default(cuid())
  projectId      String?
  title          String
  decision       String  @db.Text
  context        String? @db.Text
  consequences   String? @db.Text
  status         String  @default("active")
  supersededById String?

  sourceDocumentId String?

  decidedAt DateTime @default(now())
  createdAt DateTime @default(now())

  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceDoc Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([projectId, decidedAt])
}

// Daily notes used to live in a dedicated table; ADR-0050 merged them
// into Document (source='daily', metadata.date YYYY-MM-DD, metadata.mood).
// The /ask sidebar groups Document(source IN ('chat','daily')) by day.

// =====================================================================
// Inbox (review queue)
// =====================================================================

enum InboxItemType {
  link_suggestion
  entity_merge_suggestion
  duplicate_detection
  enrichment_failed
  conflicting_decision
}

model InboxItem {
  id          String        @id @default(cuid())
  type        InboxItemType
  title       String
  description String        @db.Text
  payload     Json

  documentId String?
  edgeId     String?
  entityId   String?

  status     String    @default("pending")
  resolvedAt DateTime?
  resolvedBy String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

// =====================================================================
// Job queue
// =====================================================================

enum JobType {
  ingest_file
  parse_document
  enrich_document
  refresh_project_context
  rebuild_index
  export_vault
  transcribe_audio
  analyze_attachment
  // ADR-0051: detector job — scans recent batches + entity clusters and
  // emits ProjectStatus=suggested rows. Cheap heuristic SQL + at most one
  // Haiku call per candidate for naming.
  project_suggest
  // ADR-0051: async autofill job for manual projects flagged autoFill=true.
  // Pulls candidates via embedding + entity match and writes DocumentProject
  // links with linkSource=autoFill.
  project_autofill
}

enum JobStatus {
  queued
  running
  paused
  completed
  failed
  cancelled
}

model Job {
  id       String    @id @default(cuid())
  type     JobType
  status   JobStatus @default(queued)
  priority Int       @default(50)

  payload Json
  result  Json?
  error   String? @db.Text

  documentId String?

  attempts    Int @default(0)
  maxAttempts Int @default(3)

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  costEstimate Int?

  @@index([status, priority, createdAt])
  @@index([documentId])
}

// =====================================================================
// Audit log
// =====================================================================

model AuditLog {
  id         String  @id @default(cuid())
  action     String
  actor      String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

// =====================================================================
// System tables
// =====================================================================

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// =====================================================================
// LLM providers (ADR-0049) — pluggable AI backends for Ask / enrichment /
// vision / project-context. The built-in `Claude Code (CLI)` subprocess is
// virtual and never persisted; any row here represents a user-configured
// Anthropic-API or OpenAI-compatible endpoint. `apiKeyEnc` holds the
// AES-256-GCM ciphertext (IV‖tag‖ct) of the plaintext token; the master
// key lives outside the DB (env or data-dir keystore file).
// =====================================================================

enum LlmProviderKind {
  claude_cli
  anthropic_api
  openai_compat
}

model LlmProvider {
  id        String          @id @default(cuid())
  name      String
  kind      LlmProviderKind
  model     String
  baseUrl   String?
  apiKeyEnc Bytes?
  /// Free-form provider settings (extra HTTP headers, OpenAI org, etc.).
  extra     Json?
  /// `last4` of the plaintext key, persisted so the UI can show "sk-…1234"
  /// without round-tripping through decrypt + log redaction. `null` when
  /// the provider needs no key (local Ollama with no auth).
  apiKeyLast4 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

model AuthToken {
  id        String  @id @default(cuid())
  name      String
  tokenHash String  @unique
  scope     String

  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
}

model AdminUser {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String

  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  conversations Conversation[]
}

// =====================================================================
// Ask Brain — conversations and messages (Phase 8, ADR-0039)
// =====================================================================

enum MessageRole {
  user
  assistant
  system
}

// Ephemeral messages are chat-only (cost-free, no graph footprint).
// Pinned messages are promoted to Document(source='chat') after the
// assistant finishes, so the same Q&A flows through enrichment and
// becomes a first-class node in the knowledge graph (ADR-0050).
enum MessageKind {
  ephemeral
  pinned
}

model Conversation {
  id                  String  @id @default(cuid())
  adminUserId         String
  title               String
  synthesisDocumentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUser         AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  synthesisDocument Document? @relation("ConversationSynthesis", fields: [synthesisDocumentId], references: [id], onDelete: SetNull)
  messages          Message[]
  telegramLinks     TelegramChatLink[]

  @@index([adminUserId, createdAt(sort: Desc)])
  @@index([adminUserId, updatedAt(sort: Desc)])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  kind           MessageKind @default(ephemeral)
  contentMd      String      @db.Text
  citations      Json        @default("[]")
  tokensIn       Int?
  tokensOut      Int?
  /// USD spent for this message turn — populated by api/.../search at
  /// persist time from the per-model rate table (see Phase 11 Bucket
  /// C). Null for CLI-backed turns that don't emit usage frames and
  /// for messages predating the rate table.
  costUsd        Decimal?    @db.Decimal(10, 6)
  /// Soft FK — the LlmProvider that produced the message. No
  /// constraint, so deleting a provider doesn't rewrite history.
  providerId     String?
  /// Breadcrumb of the model id at call time. Survives provider rename.
  model          String?
  durationMs     Int?
  dumbMode       Boolean     @default(false)
  aborted        Boolean     @default(false)
  /// When kind='pinned' and the post-answer promotion succeeded, the
  /// linked Document's id. Cleared when the document is deleted.
  pinnedDocumentId String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([kind, pinnedDocumentId])
}

// =====================================================================
// Telegram bot integration (ADR-0053) — single-tenant Telegram frontend
// to /search/ask + /documents/upload. Config lives in the singleton-id
// TelegramBot row (token AES-256-GCM-encrypted in `tokenEnc`, master key
// shared with LlmProvider via `@mnela/llm-providers/keystore`). Access
// gated by TelegramAllowedUser whitelist; chat-to-conversation mapping
// in TelegramChatLink so multi-turn /ask state lives in the existing
// Conversation/Message tables, not in a parallel store.
// =====================================================================

enum TelegramTransport {
  polling
  webhook
}

model TelegramBot {
  /// Always the literal string "singleton" — the table holds exactly one row,
  /// upserted by id. This keeps the controller stateless and avoids the need
  /// for a per-row repo.
  id String @id

  enabled  Boolean @default(false)
  /// AES-256-GCM ciphertext (IV‖tag‖ct) of the plaintext bot token. Same
  /// keystore as LlmProvider.apiKeyEnc — `MNELA_PROVIDER_SECRET` or the
  /// auto-generated `$MNELA_DATA_DIR/keystore/provider.key`.
  tokenEnc Bytes?
  /// Last 4 chars of the plaintext token, persisted so the UI can render
  /// "…1234" without round-tripping through decrypt + log redaction.
  tokenLast4 String?

  /// Cached `getMe()` identity — refreshed on Test Connection. Lets the bot
  /// recognise its own messages and lets the UI show "Connected as @foo".
  botUsername String?
  botId       BigInt?

  transport          TelegramTransport @default(polling)
  webhookUrl         String?
  /// Debounce window for multi-modal turn bundling. New messages within
  /// this window are collected into a single conversational turn before
  /// the bot replies. 4000 ms is a deliberate compromise: long enough to
  /// catch "voice → photo → text" sequences, short enough that single
  /// utterances feel responsive.
  bundleWindowMs     Int               @default(4000)
  /// Optional default project slug — every TelegramChatLink that doesn't
  /// have its own scopeSlug falls back to this. Set via /admin/system.
  defaultProjectSlug String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramAllowedUser {
  /// Telegram user_id (64-bit). Bot only processes messages whose
  /// `from.id` matches a row here.
  tgUserId  BigInt   @id
  label     String?
  createdAt DateTime @default(now())
}

model TelegramChatLink {
  /// Telegram chat_id (64-bit). For private chats this equals the user's
  /// tgUserId; for groups it's the group chat id.
  tgChatId BigInt @id

  /// Mnela Conversation backing this Telegram chat. Created lazily on the
  /// first message of the chat and reused for every subsequent turn so
  /// `/search/ask` sees a continuous multi-turn thread per chat.
  conversationId String?
  /// Sticky `/scope <slug>` for this chat. When set, every /ask call from
  /// this chat passes `scopeProjectSlug` and every ingest passes
  /// `projects: [slug]`. `/scope` with no arg clears it.
  scopeSlug      String?
  /// Wall-clock of the last completed turn — handy for "what was the last
  /// thing we talked about in this chat" queries / debugging.
  lastTurnAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([conversationId])
}
