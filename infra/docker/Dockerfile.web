# syntax=docker/dockerfile:1.7
#
# apps/web — Next.js 15 (App Router). Builds with `output: 'standalone'` so
# the runtime image only carries `.next/standalone` + `.next/static` +
# `public`. Stay on node:22-slim end-to-end so the Sharp prebuilt binary
# Next bundles for image optimisation just works.

FROM node:22-slim AS builder

ENV PNPM_HOME=/pnpm \
    PATH="/pnpm:$PATH" \
    CI=true \
    NEXT_TELEMETRY_DISABLED=1

RUN apt-get update \
 && apt-get install -y --no-install-recommends openssl ca-certificates python3 build-essential \
 && rm -rf /var/lib/apt/lists/* \
 && corepack enable

WORKDIR /repo

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/
COPY apps/mcp/package.json apps/mcp/
COPY apps/cli/package.json apps/cli/
COPY apps/orchestrator/package.json apps/orchestrator/
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY apps/tg-bot/package.json apps/tg-bot/
COPY packages ./packages-manifests-only
RUN find packages-manifests-only -mindepth 2 -maxdepth 2 -name 'package.json' -exec sh -c \
    'mkdir -p packages/$(basename $(dirname "$1")) && cp "$1" packages/$(basename $(dirname "$1"))/package.json' _ {} \; \
 && rm -rf packages-manifests-only

RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

COPY . .
RUN pnpm exec turbo run build --filter=@mnela/web...

# ---------- runtime ----------
FROM node:22-slim AS runtime

RUN apt-get update \
 && apt-get install -y --no-install-recommends tini ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd -r mnela \
 && useradd -r -g mnela -d /app -s /usr/sbin/nologin mnela

WORKDIR /app

# Three standalone bits: the server, the static chunks (must live under
# .next/static), and the public assets. Order: server first so the
# subsequent COPYs land at the canonical paths Next expects.
COPY --from=builder --chown=mnela:mnela /repo/apps/web/.next/standalone ./
COPY --from=builder --chown=mnela:mnela /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=mnela:mnela /repo/apps/web/public ./apps/web/public
COPY --chown=mnela:mnela infra/docker/healthcheck.js ./healthcheck.js

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=3001 \
    HEALTHCHECK_PORT=3001 \
    HEALTHCHECK_PATH=/

USER mnela
EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD ["node", "healthcheck.js"]

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "apps/web/server.js"]
