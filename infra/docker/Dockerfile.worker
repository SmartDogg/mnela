# syntax=docker/dockerfile:1.7
#
# apps/worker — BullMQ consumer for ingestion (chatgpt/claude ZIPs, attachments,
# folder watcher on $MNELA_DATA_DIR/dropbox/). No HTTP surface, no healthcheck.
# Same builder layout as Dockerfile.api.

FROM node:22-slim AS builder

ENV PNPM_HOME=/pnpm \
    PATH="/pnpm:$PATH" \
    CI=true

RUN apt-get update \
 && apt-get install -y --no-install-recommends openssl ca-certificates python3 build-essential \
 && rm -rf /var/lib/apt/lists/* \
 && corepack enable

WORKDIR /repo

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/
COPY apps/mcp/package.json apps/mcp/
COPY apps/cli/package.json apps/cli/
COPY apps/orchestrator/package.json apps/orchestrator/
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY apps/tg-bot/package.json apps/tg-bot/
COPY packages ./packages-manifests-only
RUN find packages-manifests-only -mindepth 2 -maxdepth 2 -name 'package.json' -exec sh -c \
    'mkdir -p packages/$(basename $(dirname "$1")) && cp "$1" packages/$(basename $(dirname "$1"))/package.json' _ {} \; \
 && rm -rf packages-manifests-only

RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

COPY . .
RUN pnpm --filter @mnela/db exec prisma generate
RUN pnpm exec turbo run build --filter=@mnela/worker...
RUN pnpm --filter @mnela/worker deploy --prod /out

# Regenerate the Prisma client inside the deployed tree (see
# Dockerfile.api for the reasoning).
RUN PRISMA_CLI=$(find /repo/node_modules/.pnpm -path '*/prisma/build/index.js' -type f -print -quit) \
 && [ -n "$PRISMA_CLI" ] || { echo "prisma CLI not found in builder pnpm store"; exit 1; } \
 && cd /out && node "$PRISMA_CLI" generate --schema=node_modules/@mnela/db/prisma/schema.prisma

# ---------- runtime ----------
FROM node:22-slim AS runtime

# ffmpeg comes from the ffmpeg-static prebuilt; we still need libraries the
# rest of the worker stack needs (file probing) — keep only what we use.
RUN apt-get update \
 && apt-get install -y --no-install-recommends tini openssl ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd -r mnela \
 && useradd -r -g mnela -d /app -s /usr/sbin/nologin mnela

WORKDIR /app
COPY --from=builder --chown=mnela:mnela /out/dist ./dist
COPY --from=builder --chown=mnela:mnela /out/node_modules ./node_modules
COPY --from=builder --chown=mnela:mnela /out/package.json ./package.json

RUN mkdir -p /data && chown -R mnela:mnela /data

ENV NODE_ENV=production \
    MNELA_DATA_DIR=/data

USER mnela

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "dist/main.js"]
