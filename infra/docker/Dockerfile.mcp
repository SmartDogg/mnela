# syntax=docker/dockerfile:1.7

# ---------- builder ----------
FROM node:22-alpine AS builder

ENV PNPM_HOME=/pnpm \
    PATH="/pnpm:$PATH" \
    CI=true
RUN corepack enable

WORKDIR /repo

# Copy workspace manifests first to maximise layer cache hits on dep installs.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/mcp/package.json apps/mcp/
COPY apps/api/package.json apps/api/
COPY apps/cli/package.json apps/cli/
COPY apps/orchestrator/package.json apps/orchestrator/
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY packages ./packages-manifests-only
RUN find packages-manifests-only -mindepth 2 -maxdepth 2 -name 'package.json' -exec sh -c \
    'mkdir -p packages/$(basename $(dirname $1)) && cp $1 packages/$(basename $(dirname $1))/package.json' _ {} \; \
    && rm -rf packages-manifests-only

RUN pnpm install --frozen-lockfile

# Now copy the rest of the source and build.
COPY . .
# @mnela/mcp imports @mnela/db (and through it the Prisma Client).
# Generate the Prisma Client before tsc so typed exports resolve.
RUN pnpm --filter @mnela/db exec prisma generate
RUN pnpm exec turbo run build --filter=@mnela/mcp...

# Prune to production-only deps for the runtime stage.
RUN pnpm --filter @mnela/mcp deploy --prod /out

# Regenerate the Prisma client inside the deployed tree (see
# Dockerfile.api for the reasoning).
RUN PRISMA_CLI=$(find /repo/node_modules/.pnpm -path '*/prisma/build/index.js' -type f -print -quit) \
 && [ -n "$PRISMA_CLI" ] || { echo "prisma CLI not found in builder pnpm store"; exit 1; } \
 && cd /out && node "$PRISMA_CLI" generate --schema=node_modules/@mnela/db/prisma/schema.prisma

# ---------- runtime ----------
FROM node:22-alpine AS runtime

RUN apk add --no-cache wget tini \
    && addgroup -S mnela \
    && adduser -S -G mnela mnela

WORKDIR /app
COPY --from=builder --chown=mnela:mnela /out/dist ./dist
COPY --from=builder --chown=mnela:mnela /out/node_modules ./node_modules
COPY --from=builder --chown=mnela:mnela /out/package.json ./package.json

ENV NODE_ENV=production \
    MCP_HTTP_PORT=3010

USER mnela
EXPOSE 3010

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD wget -qO- http://localhost:3010/health || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "dist/main.js"]
