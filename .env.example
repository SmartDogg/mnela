# --- Required ---
NODE_ENV=development

# Database
POSTGRES_USER=mnela
POSTGRES_PASSWORD=mnela_dev_password_change_me
POSTGRES_DB=mnela
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mnela:mnela_dev_password_change_me@localhost:5432/mnela?schema=public

# Redis
REDIS_PASSWORD=mnela_dev_redis_change_me
REDIS_PORT=6379
REDIS_URL=redis://default:mnela_dev_redis_change_me@localhost:6379

# Auth
JWT_SECRET=replace_with_64_random_bytes_in_production
# Used to sign session cookies; rotate to invalidate all sessions.
COOKIE_SECRET=replace_with_32_plus_random_bytes
SESSION_TTL_SECONDS=604800
# Optional: bootstrap an initial admin if AdminUser table is empty.
# Wizard in Phase 3 will replace this. Password must be 12+ chars.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=please_change_me_immediately

# Search blend tuning (defaults: 0.7 fts + 0.3 trigram, 0.3 trigram threshold)
SEARCH_FTS_WEIGHT=0.7
SEARCH_TRIGRAM_WEIGHT=0.3
SEARCH_TRIGRAM_THRESHOLD=0.3

# Rate limit windows (per minute)
RATE_LIMIT_GLOBAL_PER_MINUTE=100
RATE_LIMIT_LOGIN_PER_MINUTE=10

# Application
MNELA_DOMAIN=localhost
MNELA_BIND_MODE=ip
MNELA_DATA_DIR=./data
MNELA_LOG_LEVEL=info

# --- Claude Code orchestrator ---
MNELA_CLAUDE_MODE=disabled
MNELA_CLAUDE_MAX_CONCURRENT=1
MNELA_CLAUDE_RATE_LIMIT_PER_HOUR=30
MNELA_CLAUDE_TIMEOUT_SECONDS=180

# --- Optional modules ---
# Voice transcription via whisper.cpp HTTP container. When set to "enabled":
#   1. Start the whisper service:
#        docker compose -f infra/docker/docker-compose.yml \
#          -f infra/docker/docker-compose.optional.yml \
#          --profile optional up -d whisper
#   2. Worker probes whisper at boot and writes mnela:whisper:status.
#   3. Audio uploads transcribe automatically; existing status='raw'
#      audio backfills via POST /api/v1/system/transcribe-pending.
MNELA_TRANSCRIPTION=disabled
MNELA_TRANSCRIPTION_LANGUAGE=ru
# whisper.cpp model — base ≈140MB (recommended for VPS), small ≈466MB, medium ≈1.5GB.
# Changing this requires rebuilding the whisper image: `docker compose build whisper`.
MNELA_WHISPER_MODEL=base
# Container DNS name within the compose network. Override only for bare-metal setups.
WHISPER_URL=http://whisper:8080
WHISPER_TIMEOUT_MS=120000
MNELA_EMBEDDINGS=disabled

# --- MCP server ---
MNELA_MCP_PUBLIC_URL=http://localhost:3001/mcp
MNELA_MCP_READ_ONLY=false

# --- Backups ---
MNELA_BACKUP_ENABLED=false
MNELA_BACKUP_SCHEDULE="0 4 * * *"
MNELA_BACKUP_RETENTION_DAYS=14

# --- Cloudflare Tunnel (production only, leave blank in dev) ---
CF_TUNNEL_TOKEN=

# --- Telegram bot (ADR-0053) ---
# Service-bearer token apps/tg-bot uses to call /search/ask + /documents/upload.
# Issue under /admin/system → API tokens with scope `mcp` (the plaintext is
# shown ONCE on creation). The Telegram bot token from @BotFather itself
# does NOT live here — store it via /admin/system → Telegram, where it is
# AES-256-GCM-encrypted with the same keystore as LlmProvider.apiKeyEnc.
MNELA_INTERNAL_TOKEN=

# When running the worker on the host (pnpm dev) instead of inside the
# compose network, the docker DNS name `whisper` isn't reachable — point
# WHISPER_URL at the host-mapped port. Bring up the host-overlay with:
#   docker compose -f infra/docker/docker-compose.yml \
#     -f infra/docker/docker-compose.optional.yml \
#     -f infra/docker/docker-compose.whisper-host.yml \
#     --profile optional up -d whisper
# WHISPER_URL=http://127.0.0.1:8090
