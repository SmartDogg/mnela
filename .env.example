# Mnela — out-of-the-box .env template
#
# Most user-facing settings live in SystemConfig and are tunable from
# /admin/system at runtime; this file is for boot-critical / secret /
# deploy-infra values only. The "Restart services" button in the admin
# UI hot-reloads the registry-driven settings without touching env.

# --- Required ---
NODE_ENV=development

# Database
POSTGRES_USER=mnela
POSTGRES_PASSWORD=mnela_dev_password_change_me
POSTGRES_DB=mnela
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mnela:mnela_dev_password_change_me@localhost:5432/mnela?schema=public

# Redis
REDIS_PASSWORD=mnela_dev_redis_change_me
REDIS_PORT=6379
REDIS_URL=redis://default:mnela_dev_redis_change_me@localhost:6379

# Auth
# Signs session cookies; rotate to invalidate every existing session.
# Mnela uses Redis-backed sessions (ADR-0007), not JWTs.
COOKIE_SECRET=replace_with_32_plus_random_bytes
SESSION_TTL_SECONDS=604800
# ---
# Non-interactive admin bootstrap (DO NOT enable for normal installs).
# The Setup Wizard at /setup → POST /auth/bootstrap is the supported
# first-admin flow. These env vars are only consulted when the
# AdminUser table is empty AT BOOT, which means automated CI deploys
# can pre-create an admin without ever rendering the wizard. Leave them
# unset and the wizard will run on first /login visit.
# ADMIN_INITIAL_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=please_change_me_immediately

# Application
MNELA_DATA_DIR=./data
# Where backup .tar.gz bundles land. In production the mnela-backups
# named volume is mounted at /backups in the api container; in dev the
# api process resolves this to a sibling of MNELA_DATA_DIR (./backups).
# Both CLI (scripts/backup.sh) and UI (/admin/system → Backups) write
# to the same location.
# MNELA_BACKUPS_DIR=/backups
MNELA_LOG_LEVEL=info

# Boot fallback for the global rate limit. Live tuning lives at
# /admin/system → API limits (key: api.rateLimit.global). The env value
# is read once at startup before SystemConfig is reachable; the
# registry override takes precedence after that.
RATE_LIMIT_GLOBAL_PER_MINUTE=100

# AES-256-GCM master key for the encrypted-secret keystore (provider
# API keys, Telegram bot token). Hex (64 chars) / base64 (44 chars) /
# passphrase all accepted. Leave blank to auto-generate one in
# <MNELA_DATA_DIR>/keystore/provider.key on first boot.
# MNELA_PROVIDER_SECRET=

# --- Whisper transcription (ADR-0045, optional) ---
# Voice transcription via whisper.cpp HTTP container. User-facing knobs
# (on/off, model, language) live in SystemConfig — configure them under
# /admin/system → Transcription, no .env edits required. To enable:
#   1. Start the whisper service:
#        docker compose -f infra/docker/docker-compose.yml \
#          -f infra/docker/docker-compose.optional.yml \
#          --profile optional up -d whisper
#   2. Toggle `transcription.enabled` in /admin/system. The worker
#      reads the registry on every ingest; the toggle takes effect on
#      the next audio message with no restart.
#
# When running the worker on the host (pnpm dev) instead of inside the
# compose network, the docker DNS name `whisper` isn't reachable —
# point WHISPER_URL at the host-mapped port. Bring up the host-overlay:
#   docker compose -f infra/docker/docker-compose.yml \
#     -f infra/docker/docker-compose.optional.yml \
#     -f infra/docker/docker-compose.whisper-host.yml \
#     --profile optional up -d whisper
# WHISPER_URL=http://127.0.0.1:8090
WHISPER_URL=http://whisper:8080
WHISPER_TIMEOUT_MS=120000

# --- Telegram bot (ADR-0053, optional) ---
# Service-bearer token apps/tg-bot uses to call /search/ask +
# /documents/upload. Issue under /admin/system → API tokens with scope
# `mcp` (the plaintext is shown ONCE on creation). The Telegram bot
# token from @BotFather itself does NOT live here — store it via
# /admin/system → Telegram, where it is AES-256-GCM-encrypted with the
# same keystore as LlmProvider.apiKeyEnc.
MNELA_INTERNAL_TOKEN=

# --- Cloudflare Tunnel (production only, leave blank in dev) ---
CF_TUNNEL_TOKEN=

# --- Advanced (defaults work; override only when you know why) ---
# api process bind. Default 0.0.0.0:3000.
# HTTP_HOST=0.0.0.0
# HTTP_PORT=3000

# Where the web process reaches the api. The web proxy under /_api uses
# MNELA_API_INTERNAL_BASE on the server side (server-to-server, container
# network); MNELA_API_ORIGIN / NEXT_PUBLIC_MNELA_API_ORIGIN are the
# browser-facing origin used by absolute-url helpers. Defaults assume
# both processes run on localhost.
# MNELA_API_INTERNAL_BASE=http://localhost:3000
# MNELA_API_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_MNELA_API_ORIGIN=http://localhost:3000

# MCP host port (apps/mcp). Default 3030.
# MCP_HTTP_PORT=3030

# Claude CLI subprocess settings (consumed by ClaudeCliProvider through
# packages/claude-runner). All optional — leave commented if `claude`
# is on PATH and you don't need custom timeouts. Mode/concurrency/rate
# previously lived here as MNELA_CLAUDE_* env; they now live in
# SystemConfig under /admin/system → Providers (ADR-0049).
# MNELA_CLAUDE_BIN=claude
# MNELA_CLAUDE_TIMEOUT_MS=180000
# MNELA_CLAUDE_VAULT_DIR=
# MNELA_CLAUDE_MCP_CONFIG=

# Ask Brain Dumb Mode FTS cap (ADR-0029). Defaults to 20.
# ASK_DUMB_MODE_FTS_LIMIT=20
