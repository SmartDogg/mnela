# --- Required ---
NODE_ENV=development

# Database
POSTGRES_USER=mnela
POSTGRES_PASSWORD=mnela_dev_password_change_me
POSTGRES_DB=mnela
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mnela:mnela_dev_password_change_me@localhost:5432/mnela?schema=public

# Redis
REDIS_PASSWORD=mnela_dev_redis_change_me
REDIS_PORT=6379
REDIS_URL=redis://default:mnela_dev_redis_change_me@localhost:6379

# Auth
JWT_SECRET=replace_with_64_random_bytes_in_production
# Used to sign session cookies; rotate to invalidate all sessions.
COOKIE_SECRET=replace_with_32_plus_random_bytes
SESSION_TTL_SECONDS=604800
# Optional: bootstrap an initial admin if AdminUser table is empty.
# Wizard in Phase 3 will replace this. Password must be 12+ chars.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=please_change_me_immediately

# Search blend tuning (defaults: 0.7 fts + 0.3 trigram, 0.3 trigram threshold)
SEARCH_FTS_WEIGHT=0.7
SEARCH_TRIGRAM_WEIGHT=0.3
SEARCH_TRIGRAM_THRESHOLD=0.3

# Rate limit windows (per minute)
RATE_LIMIT_GLOBAL_PER_MINUTE=100
RATE_LIMIT_LOGIN_PER_MINUTE=10

# Application
MNELA_DOMAIN=localhost
MNELA_BIND_MODE=ip
MNELA_DATA_DIR=./data
MNELA_LOG_LEVEL=info

# --- Claude Code orchestrator ---
MNELA_CLAUDE_MODE=disabled
MNELA_CLAUDE_MAX_CONCURRENT=1
MNELA_CLAUDE_RATE_LIMIT_PER_HOUR=30
MNELA_CLAUDE_TIMEOUT_SECONDS=180

# --- Optional modules ---
MNELA_TRANSCRIPTION=disabled
MNELA_TRANSCRIPTION_LANGUAGE=ru
MNELA_EMBEDDINGS=disabled

# --- MCP server ---
MNELA_MCP_PUBLIC_URL=http://localhost:3001/mcp
MNELA_MCP_READ_ONLY=false

# --- Backups ---
MNELA_BACKUP_ENABLED=false
MNELA_BACKUP_SCHEDULE="0 4 * * *"
MNELA_BACKUP_RETENTION_DAYS=14

# --- Cloudflare Tunnel (production only, leave blank in dev) ---
CF_TUNNEL_TOKEN=
