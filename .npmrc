auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=true
save-workspace-protocol=rolling
# pnpm v10+ changed `pnpm deploy` to require inject-workspace-packages
# by default. Production Dockerfiles use `pnpm deploy --prod /out` to
# materialise a flat tree; sticking to legacy keeps the existing build
# graph working without touching every workspace package.json.
force-legacy-deploy=true
