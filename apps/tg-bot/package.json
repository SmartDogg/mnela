{
  "name": "@mnela/tg-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --env-file=../../.env --watch --enable-source-maps --import @swc-node/register/esm-register src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@grammyjs/files": "^1.1.1",
    "@mnela/core": "workspace:*",
    "@mnela/db": "workspace:*",
    "@mnela/llm-providers": "workspace:*",
    "@mnela/queue": "workspace:*",
    "@mnela/shared-types": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@prisma/client": "^6.1.0",
    "grammy": "^1.36.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.8"
  }
}
